<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- MAIN CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Solar Device"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <!-- DEVICE ID -->
            <EditText
                android:id="@+id/etDeviceId_GIT"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Enter Device ID"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF"
                android:background="@drawable/glass_input"
                android:padding="14dp"
                android:layout_marginTop="30dp"/>

            <!-- SEND OTP -->
            <Button
                android:id="@+id/btnSendOtp_GIT"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Send OTP"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:layout_marginTop="15dp"/>

            <!-- OTP -->
            <EditText
                android:id="@+id/etOtp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Enter OTP"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF"
                android:background="@drawable/glass_input"
                android:padding="14dp"
                android:layout_marginTop="20dp"
                android:inputType="number"/>

            <!-- VERIFY DEVICE -->
            <Button
                android:id="@+id/btnVerifyDevice"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Verify Device"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginTop="15dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>